# =============================================================================
# Glassdoor Scraper configuration. Copy to .env and fill in real values, or set
# these in your shell / secret store. Everything is optional except the proxy
# credentials (without them Cloudflare will block a datacenter/home IP) and, if
# you use webhooks, GLASSDOOR_WEBHOOK_SECRET.
#
# All variables are prefixed GLASSDOOR_ except the two DataImpulse aliases, which
# keep their original names for backward compatibility.
# =============================================================================

# ---- DataImpulse residential proxy credentials (from your dashboard) --------
DATAIMPULSE_USER=your_dataimpulse_login
DATAIMPULSE_PASS=your_dataimpulse_password

# ---- Anti-detection fingerprint ---------------------------------------------
# The curl_cffi impersonation target that currently passes Cloudflare. Override
# if chrome136 stops working (see the ops runbook in the README).
GLASSDOOR_IMPERSONATE=chrome136
# Ordered fallback chain tried automatically on persistent 403s (comma-separated).
GLASSDOOR_IMPERSONATE_FALLBACKS=chrome136,chrome142,chrome145,chrome133a,chrome124

# ---- Proxy gateway (defaults match DataImpulse; rarely need changing) --------
# GLASSDOOR_PROXY_HOST=gw.dataimpulse.com
# GLASSDOOR_PROXY_ROTATING_PORT=823
# GLASSDOOR_PROXY_STICKY_PORT=10000
# GLASSDOOR_PROXY_COUNTRY=us

# ---- Request pacing / retries -----------------------------------------------
GLASSDOOR_DELAY_MIN=3.0
GLASSDOOR_DELAY_MAX=5.0
GLASSDOOR_REQUEST_TIMEOUT=20
GLASSDOOR_MAX_RETRIES=3
GLASSDOOR_BACKOFF_BASE=5.0

# ---- Global token-bucket rate limiter (shared across all workers) -----------
GLASSDOOR_RATE_LIMIT_PER_SEC=1.0
GLASSDOOR_RATE_LIMIT_BURST=3.0

# ---- Concurrency / resilience -----------------------------------------------
GLASSDOOR_WORKER_COUNT=3
GLASSDOOR_CIRCUIT_BREAKER_THRESHOLD=5
GLASSDOOR_MAX_PAGES_PER_REQUEST=20

# ---- Storage / TTL / dedup --------------------------------------------------
GLASSDOOR_DB_PATH=glassdoor_scraper.db
GLASSDOOR_RESULTS_TTL_HOURS=48
GLASSDOOR_IDEMPOTENCY_WINDOW_SECONDS=300
GLASSDOOR_JOB_MAX_ATTEMPTS=3

# ---- API service ------------------------------------------------------------
GLASSDOOR_API_HOST=0.0.0.0
GLASSDOOR_API_PORT=8000
GLASSDOOR_API_RESULTS_PAGE_SIZE=50
GLASSDOOR_MAX_PAYLOAD_BYTES=16384

# ---- Auth / quotas ----------------------------------------------------------
# Set to false to disable API-key auth (local development only).
GLASSDOOR_REQUIRE_API_KEY=true
GLASSDOOR_DEFAULT_DAILY_QUOTA=500
GLASSDOOR_DEFAULT_RATE_LIMIT_PER_MIN=60
GLASSDOOR_DEFAULT_MAX_CONCURRENT_JOBS=5

# ---- Webhooks ---------------------------------------------------------------
# HMAC-SHA256 signing secret for outbound webhook deliveries. Required if you
# submit searches with a webhook_url and want receivers to verify authenticity.
GLASSDOOR_WEBHOOK_SECRET=
GLASSDOOR_WEBHOOK_TIMEOUT=10.0
GLASSDOOR_WEBHOOK_MAX_ATTEMPTS=3

# ---- Observability / alerting -----------------------------------------------
GLASSDOOR_LOG_LEVEL=INFO
# The API service emits structured JSON logs by default.
GLASSDOOR_JSON_LOGS=true
GLASSDOOR_BLOCK_RATE_ALERT_THRESHOLD=0.5
GLASSDOOR_BLOCK_RATE_WINDOW=20
